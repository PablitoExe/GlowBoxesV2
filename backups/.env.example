# Glow Boxes — Backup environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Supabase project reference (find it in Settings > General)
SUPABASE_PROJECT_REF=luduxepqcdhuhbuobduw
SUPABASE_REGION=sa-east-1

# Supabase DB connection (Settings > Database > Connection string)
PGHOST=db.luduxepqcdhuhbuobduw.supabase.co
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=your-supabase-db-password

# Where to store backup files (absolute path, no trailing slash)
BACKUP_DIR=/home/ubuntu/backups/glowboxes

# How many backups to keep before rotating
BACKUP_KEEP=14
